# SONiC production environment configuration
# Copy to SONiC as .env in the application directory

APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080

# Use fixture mode until gNMI connectivity is verified
# Switch to 'live' after confirming sandbox reachable
DEVICE_MODE=fixture

# Cisco sandbox gNMI settings (fill in with your sandbox details)
GNMI_HOST=
GNMI_PORT=50052
GNMI_USERNAME=
GNMI_PASSWORD=
GNMI_INSECURE=true
GNMI_SKIP_VERIFY=true

# gNOI shares the gNMI port on most devices
GNOI_HOST=
GNOI_PORT=50052
GNOI_INSECURE=true
GNOI_SKIP_VERIFY=true

# Audit log location on SONiC filesystem
AUDIT_LOG_PATH=/var/log/sonic-openconfig-diagnostic-gateway/audit.jsonl
