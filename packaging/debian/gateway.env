# SONiC OpenConfig Diagnostic Gateway — Environment Configuration
# Installed by Debian package to /etc/sonic-openconfig-diagnostic-gateway/
# Edit this file with your sandbox/device credentials before starting.

APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080

# "fixture" = use pre-captured JSON (no live device needed)
# "live"    = connect to real device via gNMI
DEVICE_MODE=fixture

# Known device IDs (JSON list). Requests with unknown IDs are rejected.
KNOWN_DEVICE_IDS=["iosxe-sandbox"]

# Cisco sandbox / target device gNMI settings
# CHANGE THESE to match your environment
GNMI_HOST=devnetsandboxiosxec9k.cisco.com
GNMI_PORT=9339
GNMI_USERNAME=
GNMI_PASSWORD=
GNMI_INSECURE=false
GNMI_SKIP_VERIFY=true

# gNOI settings (usually same host/port as gNMI)
GNOI_HOST=devnetsandboxiosxec9k.cisco.com
GNOI_PORT=9339
GNOI_INSECURE=false
GNOI_SKIP_VERIFY=true

# Audit log — all description changes are recorded here
AUDIT_LOG_PATH=/var/log/sonic-openconfig-diagnostic-gateway/audit.jsonl
